@model PropertyManager.Models.WorkLogs

@{
    ViewData["Title"] = "Delete Log";
}

<h1>Delete Work Log</h1>
<h3>Are you sure you want to delete this entry?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Project</dt>
        <dd class="col-sm-9">@Model.Project?.ProjectTitle</dd>
        <dt class="col-sm-3">Clock In</dt>
        <dd class="col-sm-9">@Model.ClockInTime</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="LogID" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>