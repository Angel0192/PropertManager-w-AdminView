@model PropertyManager.Models.WorkLogs

@{
    ViewData["Title"] = "Create Log";
}

<h1>Create Work Log</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div class="form-group mb-2">
                <label asp-for="ProjectID" class="control-label">Project</label>
                <select asp-for="ProjectID" class="form-control" asp-items="ViewBag.ProjectID">
                    <option value="">-- Select a Project --</option>
                </select>
            </div>
            <div class="form-group mb-2">
                <label asp-for="ClockInTime" class="control-label">Clock In</label>
                <input asp-for="ClockInTime" class="form-control" type="datetime-local" />
            </div>
            <div class="form-group mb-2">
                <label asp-for="ClockOutTime" class="control-label">Clock Out</label>
                <input asp-for="ClockOutTime" class="form-control" type="datetime-local" />
            </div>
            <div class="form-group mb-2">
                <label asp-for="GPSLocation" class="control-label">GPS Location</label>
                <input asp-for="GPSLocation" class="form-control" />
            </div>
            <div class="form-group mb-2">
                <label asp-for="MaterialsUsed" class="control-label">Materials Used</label>
                <textarea asp-for="MaterialsUsed" class="form-control"></textarea>
            </div>
            <div class="form-group mb-2">
                <label asp-for="ProofPhotoURL" class="control-label">Photo URL</label>
                <input asp-for="ProofPhotoURL" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="VendorSignature" class="control-label">Vendor Signature</label>
                <input asp-for="VendorSignature" class="form-control" />
            </div>
            <div class="form-group">
                <input type="submit" value="Save Log" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            </div>
        </form>
    </div>
</div>