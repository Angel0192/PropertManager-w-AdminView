@model PropertyManager.Models.MaintenanceProjects

<h1>Are you sure you want to delete this Project?</h1>

<div>
    <dl class="row">
        <!-- Project Title -->
        <dt class="col-sm-3">Project Title:</dt>
        <dd class="col-sm-9">@Model.ProjectTitle</dd>

        <!-- Property -->
        <dt class="col-sm-3">Property:</dt>
        <dd class="col-sm-9">@Model.Property?.PropertyName</dd>
    
        <!-- Bid Amount -->
        <dt class="col-sm-3">Bid Amount:</dt>
        <dd class="col-sm-9">$@Model.BidAmount</dd>

        <!-- Status -->
        <dt class="col-sm-3">Status:</dt>
        <dd class="col-sm-9">@Model.Status</dd>

        <!-- Assigned Vendor -->
        <dt class="col-sm-3">Assigned Vendor:</dt>
        <dd class="col-sm-9">@Model.AssignedVendor</dd>
    </dl>

    <form asp-action="Delete" onsubmit="return confirm('WARNING: Deleting this project will also permanently erase all attached Invoices and Work Logs. Are you sure you want to proceed?');">
        <input type="hidden" asp-for="ProjectID"/>
        <button type="submit" class="btn btn-danger">Delete Forever</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>