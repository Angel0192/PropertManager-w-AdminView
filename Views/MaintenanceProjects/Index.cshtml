@model IEnumerable<PropertyManager.Models.MaintenanceProjects>

<h1>Maintenance Projects</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Maintenance Project</a>
</p>

<table class="table">
    <thead>
        <tr>

            <!-- Project Title -->
            <th>Project Title</th>

            <!-- Property -->
            <th>Property</th>

            <!-- BidAmount -->
            <th>Bid Amount</th>

            <!-- Status -->
            <th>Status</th>

            <!-- Assigned Vendor -->
            <th>Assigned Vendor</th>

            <!-- Actions -->
            <th>Actions</th>

        </tr>
    </thead>

    <tbody>

        @foreach(var item in Model){
            <tr>
                <td>@item.ProjectTitle</td>
                <td>@item.PropertyID</td>
                <td>@item.BidAmount</td>
                <td>@item.Status</td>
                <td>@item.AssignedVendor</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ProjectID">Edit</a> | 
                    <a asp-action="Details" asp-route-id="@item.ProjectID">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.ProjectID">Delete</a>
                </td>
            </tr>
        }

    </tbody>
</table>