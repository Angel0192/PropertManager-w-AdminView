@model PropertyManager.Models.RentPayment

@{
    ViewData["Title"] = "Payment Details";
}

<h1>Payment Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Payment ID</dt>
        <dd class="col-sm-9">@Model.PaymentID</dd>

        <dt class="col-sm-3">Schedule ID</dt>
        <dd class="col-sm-9">@Model.ScheduleID</dd>

        <dt class="col-sm-3">Payment Date</dt>
        <dd class="col-sm-9">@Model.PaymentDate.ToString("MMMM dd, yyyy")</dd>

        <dt class="col-sm-3">Amount Paid</dt>
        <dd class="col-sm-9">@Model.AmountPaid.ToString("C")</dd>

        <dt class="col-sm-3">Method</dt>
        <dd class="col-sm-9">@Model.PaymentMethod</dd>

        <dt class="col-sm-3">Reference</dt>
        <dd class="col-sm-9">@Model.TransactionReference</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.PaymentID" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>