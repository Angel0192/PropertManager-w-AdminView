@model PropertyManager.Models.RentPayment

@{
    ViewData["Title"] = "Record Payment";
}

<h1>Record Rent Payment</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div class="form-group mb-2">
                <label asp-for="ScheduleID" class="control-label">Rent Schedule</label>
                <select asp-for="ScheduleID" class="form-control" asp-items="ViewBag.ScheduleID">
                    <option value="">-- Select a Schedule --</option>
                </select>
            </div>

            <div class="form-group mb-2">
                <label asp-for="PaymentDate" class="control-label">Payment Date</label>
                <input asp-for="PaymentDate" type="date" class="form-control" />
            </div>

            <div class="form-group mb-2">
                <label asp-for="AmountPaid" class="control-label">Amount Paid</label>
                <input asp-for="AmountPaid" class="form-control" type="number" step="0.01" />
            </div>

            <div class="form-group mb-2">
                <label asp-for="PaymentMethod" class="control-label">Payment Method</label>
                <input asp-for="PaymentMethod" class="form-control" placeholder="e.g. Check, Zelle, Cash" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="TransactionReference" class="control-label">Transaction Reference</label>
                <input asp-for="TransactionReference" class="form-control" placeholder="Confirmation # or Check #" />
            </div>

            <div class="form-group">
                <input type="submit" value="Save Payment" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>