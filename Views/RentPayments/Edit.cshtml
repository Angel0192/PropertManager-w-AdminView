@model PropertyManager.Models.RentPayment

@{
    ViewData["Title"] = "Edit Payment";
}

<h1>Edit Payment</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <input type="hidden" asp-for="PaymentID" />
            
            <div class="form-group mb-2">
                <label asp-for="ScheduleID" class="control-label">Rent Schedule</label>
                <select asp-for="ScheduleID" class="form-control" asp-items="ViewBag.ScheduleID">
                    <option value="">-- Select a Schedule --</option>
                </select>
            </div>

            <div class="form-group mb-2">
                <label asp-for="PaymentDate" class="control-label"></label>
                <input asp-for="PaymentDate" type="date" class="form-control" />
            </div>

            <div class="form-group mb-2">
                <label asp-for="AmountPaid" class="control-label"></label>
                <input asp-for="AmountPaid" class="form-control" type="number" step="0.01" />
            </div>

            <div class="form-group mb-2">
                <label asp-for="PaymentMethod" class="control-label"></label>
                <input asp-for="PaymentMethod" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="TransactionReference" class="control-label"></label>
                <input asp-for="TransactionReference" class="form-control" />
            </div>

            <div class="form-group">
                <input type="submit" value="Save Changes" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>