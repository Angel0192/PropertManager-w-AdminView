@model IEnumerable<PropertyManager.Models.Invoices>

@{
    ViewData["Title"] = "Invoices";
}

<h1>Invoices</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Invoice</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Project</th>
            <th>Rent Status</th>
            <th>Invoice Date</th>
            <th>Amount</th>
            <th>Exported</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.InvoiceID</td>
                
                <td>@(item.Project?.ProjectTitle ?? "N/A")</td>

                <td>ID: @(item.ScheduleID?.ToString() ?? "Empty")</td>
                
                <td>@item.InvoiceDate.ToString("MM/dd/yyyy")</td>
                <td>@item.TotalAmount.ToString("C")</td>
                <td>@(item.IsExported ? "Yes" : "No")</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.InvoiceID">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.InvoiceID">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.InvoiceID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>